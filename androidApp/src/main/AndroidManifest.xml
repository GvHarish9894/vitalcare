<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Vitals reminders (D-032) — requested at runtime only when the user
         enables the reminder toggle, never at app start. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Advertising ID: VitalCare shows no ads and does no ad attribution, so we
         opt out entirely (D-028, privacy policy). Firebase Analytics auto-injects
         AD_ID via play-services-measurement; strip it so Data Safety can truthfully
         declare "no advertising ID". -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID"
        tools:node="remove" />

    <!-- allowBackup=false: health data must not leave the device via OS
         backup transports (§07/3); the app has its own opt-in backup. -->
    <application
        android:name=".VitalCareApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- Belt-and-suspenders with the AD_ID permission removal above: tell the
             Analytics SDK never to collect the advertising ID (D-028). -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />
        <!-- adjustResize ensures the window resizes when the IME shows;
             edge-to-edge additionally requires Compose to consume IME insets
             (imePadding on scrollable/keyboard-hosting screens). -->
        <activity
            android:exported="true"
            android:launchMode="singleTop"
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Shares CSV exports from app cache (05 §3). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
